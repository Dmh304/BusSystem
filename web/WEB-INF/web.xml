<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
                             https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <display-name>BusManagementSystem</display-name>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>LoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>LogoutServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DemoTimeServlet</servlet-name>
        <servlet-class>DemoTimeServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>ParentDashboardServlet</servlet-name>
        <servlet-class>ParentDashboardServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ParentRegistrationServlet</servlet-name>
        <servlet-class>ParentRegistrationServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ParentTripStatusServlet</servlet-name>
        <servlet-class>ParentTripStatusServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>ManagerDashboardServlet</servlet-name>
        <servlet-class>ManagerDashboardServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ManagerManifestServlet</servlet-name>
        <servlet-class>ManagerManifestServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ManagerBoardingServlet</servlet-name>
        <servlet-class>ManagerBoardingServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ManagerTrackingServlet</servlet-name>
        <servlet-class>ManagerTrackingServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>DriverDashboardServlet</servlet-name>
        <servlet-class>DriverDashboardServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DriverBusStatusServlet</servlet-name>
        <servlet-class>DriverBusStatusServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DriverIncidentServlet</servlet-name>
        <servlet-class>DriverIncidentServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <servlet-class>AdminDashboardServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AdminUserServlet</servlet-name>
        <servlet-class>AdminUserServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AdminStudentsServlet</servlet-name>
        <servlet-class>AdminStudentsServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AdminBusServlet</servlet-name>
        <servlet-class>AdminBusServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AdminRouteServlet</servlet-name>
        <servlet-class>AdminRouteServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DemoTimeServlet</servlet-name>
        <url-pattern>/demo-time</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>ParentDashboardServlet</servlet-name>
        <url-pattern>/parent/dashboard</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ParentRegistrationServlet</servlet-name>
        <url-pattern>/parent/registration</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ParentTripStatusServlet</servlet-name>
        <url-pattern>/parent/trip-status</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>ManagerDashboardServlet</servlet-name>
        <url-pattern>/manager/dashboard</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ManagerManifestServlet</servlet-name>
        <url-pattern>/manager/manifest</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ManagerBoardingServlet</servlet-name>
        <url-pattern>/manager/boarding</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ManagerTrackingServlet</servlet-name>
        <url-pattern>/manager/tracking</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>DriverDashboardServlet</servlet-name>
        <url-pattern>/driver/dashboard</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DriverBusStatusServlet</servlet-name>
        <url-pattern>/driver/bus-status</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DriverIncidentServlet</servlet-name>
        <url-pattern>/driver/incident</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <url-pattern>/admin/dashboard</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AdminUserServlet</servlet-name>
        <url-pattern>/admin/users</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AdminStudentsServlet</servlet-name>
        <url-pattern>/admin/students</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AdminBusServlet</servlet-name>
        <url-pattern>/admin/buses</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AdminRouteServlet</servlet-name>
        <url-pattern>/admin/routes</url-pattern>
    </servlet-mapping>

    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>filter.AuthFilter</filter-class>
    </filter>
    <filter>
        <filter-name>RoleFilter</filter-name>
        <filter-class>filter.RoleFilter</filter-class>
    </filter>

    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/demo-time</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/logout</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/parent/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/manager/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/driver/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>

    <filter-mapping>
        <filter-name>RoleFilter</filter-name>
        <url-pattern>/parent/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>RoleFilter</filter-name>
        <url-pattern>/manager/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>RoleFilter</filter-name>
        <url-pattern>/driver/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>RoleFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>

</web-app>
